{
    "manifest_version": 3,
    "name": "Sublime help tool",
    "version": "1.0.0",
    "description": "An extension to provide quick access to Sublime Customer domains and resources.",

    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },

    "background": {
        "service_worker": "background/service-worker.js",
        "type": "module"
    },

    "permissions": ["storage", "activeTab", "tabs"],

    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}
